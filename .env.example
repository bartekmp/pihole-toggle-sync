# Comma-separated list of Pi-hole instance base URLs (no trailing slash).
# To set a per-instance password, embed it in the URL as http://:password@host.
# The shared PH_PASSWORD is used for any host that does not have one embedded.
PH_HOSTS=http://10.0.0.1:8053,http://10.0.0.2:8053

# Shared Pi-hole web password — used for all instances without embedded credentials.
# Leave empty if no password is set.
PH_PASSWORD=your_password

# Port to expose the UI on (default: 8087)
LISTEN_PORT=8087
